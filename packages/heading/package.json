{
  "name": "@react-email/heading",
  "version": "0.0.16",
  "description": "A block of heading text",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown ../react-email/src/components/heading/index.ts --format esm,cjs --dts --external react --outDir dist",
    "build:watch": "tsdown ../react-email/src/components/heading/index.ts --format esm,cjs --dts --external react --outDir dist --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/resend/react-email.git",
    "directory": "packages/heading"
  },
  "keywords": [
    "react",
    "email"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0 || ^19.0.0-rc"
  },
  "devDependencies": {
    "@react-email/render": "workspace:*",
    "tsconfig": "workspace:*",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
