{
  "name": "@react-email/code-inline",
  "version": "0.0.6",
  "description": "Display a predictable inline code HTML element that works on all email clients",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/resend/react-email.git",
    "directory": "packages/code-inline"
  },
  "scripts": {
    "build": "tsdown ../react-email/src/components/code-inline/index.ts --format esm,cjs --dts --external react --outDir dist",
    "build:watch": "tsdown ../react-email/src/components/code-inline/index.ts --format esm,cjs --dts --external react --outDir dist --watch",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0 || ^19.0.0-rc"
  },
  "devDependencies": {
    "@react-email/render": "workspace:*",
    "tsconfig": "workspace:*",
    "typescript": "catalog:"
  }
}
