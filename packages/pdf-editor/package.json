{
  "name": "@asym/pdf-editor",
  "version": "0.0.0",
  "description": "React PDF editor boundary for the Asym PDF Document Builder.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**",
    "readme.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react-email-compat": {
      "import": {
        "types": "./dist/react-email-compat.d.mts",
        "default": "./dist/react-email-compat.mjs"
      },
      "require": {
        "types": "./dist/react-email-compat.d.cts",
        "default": "./dist/react-email-compat.cjs"
      }
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Asymmetric-al/react-PDF.git",
    "directory": "packages/pdf-editor"
  },
  "keywords": [
    "asym",
    "pdf",
    "editor",
    "react",
    "tiptap"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0 || ^19.0.0-rc",
    "react-dom": "^18.0 || ^19.0 || ^19.0.0-rc"
  },
  "dependencies": {
    "@asym/pdf-template-schema": "workspace:*",
    "@react-email/editor": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.1.4"
  }
}
