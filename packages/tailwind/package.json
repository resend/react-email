{
  "name": "@react-email/tailwind",
  "version": "2.0.5",
  "description": "A React component to wrap emails with Tailwind CSS",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --exclude e2e",
    "test:e2e": "vitest run e2e",
    "test:watch": "vitest --exclude e2e"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/resend/react-email.git",
    "directory": "packages/tailwind"
  },
  "keywords": [
    "react",
    "email",
    "tailwind"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@react-email/body": "workspace:*",
    "@react-email/button": "workspace:*",
    "@react-email/code-block": "workspace:*",
    "@react-email/code-inline": "workspace:*",
    "@react-email/container": "workspace:*",
    "@react-email/heading": "workspace:*",
    "@react-email/hr": "workspace:*",
    "@react-email/img": "workspace:*",
    "@react-email/link": "workspace:*",
    "@react-email/preview": "workspace:*",
    "@react-email/text": "workspace:*",
    "react": "^18.0 || ^19.0 || ^19.0.0-rc"
  },
  "peerDependenciesMeta": {
    "@react-email/button": {
      "optional": true
    },
    "@react-email/body": {
      "optional": true
    },
    "@react-email/code-block": {
      "optional": true
    },
    "@react-email/code-inline": {
      "optional": true
    },
    "@react-email/container": {
      "optional": true
    },
    "@react-email/heading": {
      "optional": true
    },
    "@react-email/hr": {
      "optional": true
    },
    "@react-email/img": {
      "optional": true
    },
    "@react-email/link": {
      "optional": true
    },
    "@react-email/preview": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-email/body": "workspace:*",
    "@react-email/button": "workspace:^",
    "@react-email/code-block": "workspace:*",
    "@react-email/code-inline": "workspace:*",
    "@react-email/container": "workspace:*",
    "@react-email/head": "workspace:*",
    "@react-email/heading": "workspace:*",
    "@react-email/hr": "workspace:*",
    "@react-email/html": "workspace:*",
    "@react-email/img": "workspace:*",
    "@react-email/link": "workspace:*",
    "@react-email/preview": "workspace:*",
    "@react-email/render": "workspace:*",
    "@react-email/text": "workspace:*",
    "@responsive-email/react-email": "catalog:",
    "@types/css-tree": "catalog:",
    "@types/shelljs": "0.10.0",
    "@vitejs/plugin-react": "catalog:",
    "css-tree": "3.1.0",
    "react-dom": "catalog:",
    "shelljs": "0.10.0",
    "tsconfig": "workspace:*",
    "typescript": "catalog:",
    "vite": "catalog:",
    "yalc": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tailwindcss": "catalog:"
  }
}
