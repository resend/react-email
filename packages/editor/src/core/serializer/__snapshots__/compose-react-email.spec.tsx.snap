      name="format-detection" />
  </head>
  <body>
    <!--$--><!--html--><!--head--><!--body-->
    <table
      border="0"
      width="100%"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
      align="center">
      <tbody>
        <tr>
          <td>
            <table
              align="center"
              width="100%"
              border="0"
              cellpadding="0"
              cellspacing="0"
              role="presentation"
              style="width:100%">
              <tbody>
                <tr style="width:100%">
                  <td>
                    <p style="font-size:16px;line-height:24px;color:#1d1c1d">
                      Hi Sarah,
                    </p>
                    <p style="font-size:16px;line-height:24px;color:#1d1c1d">
                      <strong>James Liu</strong> commented on your pull request
                      <a
                        href="https://acme.example/pr/482"
                        rel="noopener noreferrer nofollow"
                        style="color:#0670DB;text-decoration-line:none"
                        target="_blank"
                        ><em>feat: rate-limited webhook retries</em></a
                      >:
                    </p>
                    <blockquote
                      style="border-left:3px solid #0670DB;padding:12px 16px;margin:16px 0;background-color:#f9fafb;font-size:15px;line-height:22px;color:#1d1c1d">
                      <p>
                        Could we use the same backoff schedule as the SMS retry
                        path? Otherwise this is great — ship it.
                      </p>
                    </blockquote>
                    <p style="margin:24px 0">
                      <a
                        href="https://acme.example/pr/482#comment-3219"
                        rel="noopener noreferrer nofollow"
                        style="color:#ffffff;text-decoration-line:none;display:inline-block;background-color:#1d1c1d;padding:10px 20px;border-radius:6px;text-decoration:none;font-weight:600"
                        target="_blank"
                        >View comment</a
                      >
                    </p>
                    <hr
                      style="width:100%;border:0;border-color:transparent;border-top:1px solid #e5e7eb;margin:40px 0 24px" />
                    <p
                      style="font-size:12px;line-height:18px;color:#6b7280;margin:0 0 8px">
                      Acme · 100 Market St, San Francisco, CA 94103
                    </p>
                    <p
                      style="font-size:12px;line-height:18px;color:#6b7280;margin:0">
                      You&#x27;re receiving this because you authored the PR.
                      <a
                        href="https://acme.example/notifications"
                        rel="noopener noreferrer nofollow"
                        style="color:#6b7280;text-decoration-line:none;text-decoration:underline"
                        target="_blank"
                        ><u>Manage notification preferences</u></a
                      >
                      ·
                      <a
                        href="https://acme.example/unsubscribe"
                        rel="noopener noreferrer nofollow"
                        style="color:#6b7280;text-decoration-line:none;text-decoration:underline"
                        target="_blank"
                        ><u>Unsubscribe</u></a
                      >
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
    <!--/$-->
  </body>
</html>
"
`;

