{
  "name": "@react-email/editor",
  "version": "0.0.0-experimental.6",
  "description": "",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./bubble-menu/primitives": {
      "import": {
        "types": "./dist/bubble-menu/primitives.d.mts",
        "default": "./dist/bubble-menu/primitives.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/primitives.d.ts",
        "default": "./dist/bubble-menu/primitives.js"
      }
    },
    "./bubble-menu/buttons": {
      "import": {
        "types": "./dist/bubble-menu/buttons.d.mts",
        "default": "./dist/bubble-menu/buttons.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/buttons.d.ts",
        "default": "./dist/bubble-menu/buttons.js"
      }
    },
    "./bubble-menu/node-selector": {
      "import": {
        "types": "./dist/bubble-menu/node-selector.d.mts",
        "default": "./dist/bubble-menu/node-selector.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/node-selector.d.ts",
        "default": "./dist/bubble-menu/node-selector.js"
      }
    },
    "./bubble-menu/link-form": {
      "import": {
        "types": "./dist/bubble-menu/link-form.d.mts",
        "default": "./dist/bubble-menu/link-form.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/link-form.d.ts",
        "default": "./dist/bubble-menu/link-form.js"
      }
    },
    "./bubble-menu/presets": {
      "import": {
        "types": "./dist/bubble-menu/presets.d.mts",
        "default": "./dist/bubble-menu/presets.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/presets.d.ts",
        "default": "./dist/bubble-menu/presets.js"
      }
    },
    "./bubble-menu/use-bubble-menu": {
      "import": {
        "types": "./dist/bubble-menu/use-bubble-menu.d.mts",
        "default": "./dist/bubble-menu/use-bubble-menu.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/use-bubble-menu.d.ts",
        "default": "./dist/bubble-menu/use-bubble-menu.js"
      }
    },
    "./bubble-menu/use-formatting-items": {
      "import": {
        "types": "./dist/bubble-menu/use-formatting-items.d.mts",
        "default": "./dist/bubble-menu/use-formatting-items.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/use-formatting-items.d.ts",
        "default": "./dist/bubble-menu/use-formatting-items.js"
      }
    },
    "./bubble-menu/use-alignment-items": {
      "import": {
        "types": "./dist/bubble-menu/use-alignment-items.d.mts",
        "default": "./dist/bubble-menu/use-alignment-items.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/use-alignment-items.d.ts",
        "default": "./dist/bubble-menu/use-alignment-items.js"
      }
    },
    "./bubble-menu/use-node-selector-items": {
      "import": {
        "types": "./dist/bubble-menu/use-node-selector-items.d.mts",
        "default": "./dist/bubble-menu/use-node-selector-items.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/use-node-selector-items.d.ts",
        "default": "./dist/bubble-menu/use-node-selector-items.js"
      }
    },
    "./bubble-menu/use-link-form": {
      "import": {
        "types": "./dist/bubble-menu/use-link-form.d.mts",
        "default": "./dist/bubble-menu/use-link-form.mjs"
      },
      "require": {
        "types": "./dist/bubble-menu/use-link-form.d.ts",
        "default": "./dist/bubble-menu/use-link-form.js"
      }
    },
    "./bubble-menu.css": "./dist/bubble-menu/bubble-menu.css"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown src/index.ts src/bubble-menu/primitives.tsx src/bubble-menu/buttons.tsx src/bubble-menu/node-selector.tsx src/bubble-menu/link-form.tsx src/bubble-menu/presets.tsx src/bubble-menu/use-bubble-menu.ts src/bubble-menu/use-formatting-items.ts src/bubble-menu/use-alignment-items.ts src/bubble-menu/use-node-selector-items.ts src/bubble-menu/use-link-form.ts --format esm,cjs --dts --external react && cp src/bubble-menu/bubble-menu.css dist/bubble-menu/bubble-menu.css",
    "build:watch": "tsdown src/index.ts src/bubble-menu/primitives.tsx src/bubble-menu/buttons.tsx src/bubble-menu/node-selector.tsx src/bubble-menu/link-form.tsx src/bubble-menu/presets.tsx src/bubble-menu/use-bubble-menu.ts src/bubble-menu/use-formatting-items.ts src/bubble-menu/use-alignment-items.ts src/bubble-menu/use-node-selector-items.ts src/bubble-menu/use-link-form.ts --format esm,cjs --dts --external react --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/resend/react-email.git",
    "directory": "packages/editor"
  },
  "keywords": [
    "react",
    "email"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@react-email/components": "workspace:*",
    "react": "^18.0 || ^19.0 || ^19.0.0-rc"
  },
  "dependencies": {
    "@tiptap/core": "^3.17.1",
    "@tiptap/extension-code-block": "^3.17.1",
    "@tiptap/extension-heading": "^3.17.1",
    "@tiptap/extension-horizontal-rule": "^3.17.1",
    "@tiptap/extension-link": "^3.17.1",
    "@tiptap/extension-placeholder": "^3.17.1",
    "@tiptap/html": "^3.17.1",
    "@tiptap/pm": "^3.17.1",
    "@tiptap/react": "^3.17.1",
    "@tiptap/starter-kit": "^3.17.1",
    "hast-util-from-html": "^2.0.3",
    "lucide-react": "^0.544.0",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/prismjs": "1.26.5",
    "tsconfig": "workspace:*",
    "typescript": "5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
