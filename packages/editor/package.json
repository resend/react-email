{
  "name": "@react-email/editor",
  "version": "0.0.0-experimental.0",
  "description": "",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --external react",
    "build:watch": "tsdown src/index.ts --format esm,cjs --dts --external react --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/resend/react-email.git",
    "directory": "packages/editor"
  },
  "keywords": [
    "react",
    "email"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0 || ^19.0.0-rc",
    "@react-email/components": "workspace:*"
  },
  "dependencies": {
    "@tiptap/core": "3.10.7",
    "@tiptap/extension-code-block": "3.10.7",
    "@tiptap/extension-heading": "3.10.7",
    "@tiptap/extension-horizontal-rule": "3.10.7",
    "@tiptap/pm": "3.10.7",
    "@tiptap/react": "3.10.7"
  },
  "devDependencies": {
    "@react-email/render": "workspace:*",
    "tsconfig": "workspace:*",
    "typescript": "5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
