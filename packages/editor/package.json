{
  "name": "@react-email/editor",
  "version": "0.0.0-experimental.6",
  "description": "",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./ui": {
      "import": {
        "types": "./dist/ui/index.d.mts",
        "default": "./dist/ui/index.mjs"
      },
      "require": {
        "types": "./dist/ui/index.d.ts",
        "default": "./dist/ui/index.js"
      }
    },
    "./ui/bubble-menu.css": "./dist/ui/bubble-menu/bubble-menu.css"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown src/index.ts src/ui/index.ts --format esm,cjs --dts --external react && mkdir -p dist/ui/bubble-menu && cp src/ui/bubble-menu/bubble-menu.css dist/ui/bubble-menu/bubble-menu.css",
    "build:watch": "tsdown src/index.ts src/ui/index.ts --format esm,cjs --dts --external react --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/resend/react-email.git",
    "directory": "packages/editor"
  },
  "keywords": [
    "react",
    "email"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@react-email/components": "workspace:*",
    "react": "^18.0 || ^19.0 || ^19.0.0-rc"
  },
  "dependencies": {
    "@tiptap/core": "^3.17.1",
    "@tiptap/extension-code-block": "^3.17.1",
    "@tiptap/extension-heading": "^3.17.1",
    "@tiptap/extension-horizontal-rule": "^3.17.1",
    "@tiptap/extension-link": "^3.17.1",
    "@tiptap/extension-placeholder": "^3.17.1",
    "@tiptap/html": "^3.17.1",
    "@tiptap/pm": "^3.17.1",
    "@tiptap/react": "^3.17.1",
    "@tiptap/starter-kit": "^3.17.1",
    "hast-util-from-html": "^2.0.3",
    "lucide-react": "^0.544.0",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/prismjs": "1.26.5",
    "tsconfig": "workspace:*",
    "typescript": "5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
