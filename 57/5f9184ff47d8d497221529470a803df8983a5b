it = omit.filter((item) =>\n    ['Text', 'Title', 'Subtitle', 'Heading', 'Bullet List', 'Numbered List', 'Quote', 'Code'].includes(item),\n  );\n\n  const hasAlignmentItems =\n    !omit.includes('Align Left') ||\n    !omit.includes('Align Center') ||\n    !omit.includes('Align Right');\n\n  return (\n    <BubbleMenu.Root\n      excludeNodes={[\n        'image',\n        'button',\n        'htmlContent',\n        'socialLinks',\n        'youtube',\n        'twitter',\n      ]}\n      placement=\"bottom\"\n      offset={8}\n      onHide={() => {\n        setIsNodeSelectorOpen(false);\n        setIsLinkSelectorOpen(false);\n      }}\n      className=\"bg-background flex w-fit divide-x divide-gray-3 rounded-xl border border-gray-3 shadow-xl dark:divide-gray-3\"\n    >\n      <BubbleMenu.NodeSelector\n        omit={nodeSelectorOmit}\n        open={isNodeSelectorOpen}\n        onOpenChange={(state) => {\n          setIsNodeSelectorOpen(state);\n          if (state) {\n            setIsLinkSelectorOpen(false);\n          }\n        }}\n        className=\"relative h-full\"\n        triggerClassName={cn(\n          'overflow-hidden rounded-l-xl flex h-full items-center gap-1',\n          'whitespace-nowrap p-2 text-sm font-medium text-gray-10',\n          'hover:bg-gray-a2 active:bg-gray-a3 dark:hover:bg-gray-a3 dark:active:bg-gray-a4',\n          '[&_svg]:h-4 [&_svg]:w-4',\n        )}\n        contentClassName={cn(\n          'mt-1',\n          dropdown.content.sizing,\n          dropdown.content.appearance,\n        )}\n        itemClassName={cn(\n          'flex items-center justify-between !pr-3',\n          dropdown.item.sizing,\n          dropdown.item.appearance.gray,\n          '[&_svg]:h-3 [&_svg]:w-3',\n        )}\n      />\n\n      {!omit.includes('Link') && (\n        <LinkSelector\n          isOpen={isLinkSelectorOpen}\n          setIsOpen={(state) => {\n            setIsLinkSelectorOpen(state);\n            setIsNodeSelectorOpen(false);\n          }}\n        